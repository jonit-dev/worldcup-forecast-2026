{
  "name": "worldcup-forecast-2026",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:ingest && concurrently -k -n api,web -c cyan,blue \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "PYTHONPATH=backend/src WC_FORECAST_DATA_DIR=data ./.venv/bin/flask --app wc_forecast.api.app run --debug",
    "dev:ingest": "FETCH_HISTORY=0 ./scripts/refresh_data.sh 2026-06-23",
    "dev:refresh": "./scripts/refresh_data.sh 2026-06-23",
    "dev:web": "npm --prefix frontend run dev -- --port 5173",
    "cf:snapshot": "PYTHONPATH=backend/src WC_FORECAST_DATA_DIR=data WC_FORECAST_AS_OF_DATE=2026-06-23 ./.venv/bin/python scripts/export_cloudflare_snapshot.py",
    "cf:build": "./scripts/refresh_data.sh 2026-06-23 && npm run cf:snapshot && npm --prefix frontend run build",
    "cf:dev": "npm run cf:build && wrangler dev",
    "cf:deploy": "npm run cf:build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260621.1",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "wrangler": "4.80.0"
  }
}
